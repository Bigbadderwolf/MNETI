{
  "name": "mneti-protocol",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "setup":         "bash scripts/setup.sh",
    "build":         "anchor build",
    "test":          "anchor test --skip-local-validator",
    "deploy:local":  "anchor deploy",
    "deploy:devnet": "anchor deploy --provider.cluster devnet",
    "keys:sync":     "anchor keys sync",
    "backend:dev":   "cd backend && npm run dev",
    "backend:relay": "cd backend && npm run oracle:relay"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/spl-token":  "^0.4.6",
    "@solana/web3.js":    "^1.91.8"
  },
  "devDependencies": {
    "@types/bn.js":   "^5.1.5",
    "@types/chai":    "^4.3.11",
    "@types/mocha":   "^10.0.6",
    "chai":           "^4.3.4",
    "mocha":          "^10.3.0",
    "ts-mocha":       "^10.0.0",
    "typescript":     "^5.3.3"
  }
}
